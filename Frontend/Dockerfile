FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt .
RUN python -m pip install --upgrade pip \
    && python -m pip install -r requirements.txt

COPY apps ./apps
COPY run.py .

EXPOSE 5000

CMD ["waitress-serve", "--host=0.0.0.0", "--port=5000", "run:app"]
